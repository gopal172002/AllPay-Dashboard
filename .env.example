# =============================================================================
# AllPay Dashboard — environment template (frontend + Docker Compose)
# =============================================================================
# Copy this file to `.env` in the same directory:
#   copy .env.example .env        (Windows)
#   cp .env.example .env          (macOS / Linux)
#
# Vite loads variables prefixed with VITE_ at build/dev time.
# Docker Compose also reads `.env` here for Razorpay variables passed to the API container.
# =============================================================================

# --- Frontend (Vite) ---------------------------------------------------------
# Base URL for API calls from the browser.
# Local dev (backend on host port 5000):
VITE_API_BASE_URL=http://localhost:5000/api
# Docker full stack (UI at http://localhost:5173, nginx proxies /api):
# VITE_API_BASE_URL=/api

# --- Razorpay (optional; used by `docker compose` for the backend service) -----
# Leave empty for local dev without live Razorpay. Set USE_RAZORPAY_UPI=true and
# fill all three secrets when enabling UPI in production.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
USE_RAZORPAY_UPI=false
