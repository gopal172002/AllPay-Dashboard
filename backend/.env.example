# =============================================================================
# AllPay Dashboard — backend API environment template
# =============================================================================
# Copy to `backend/.env` before `npm run dev` or `npm start`:
#   copy .env.example .env        (Windows, from backend/)
#   cp .env.example .env          (macOS / Linux)
# =============================================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (must match your running instance; default works with `docker compose`)
MONGO_URI=mongodb://127.0.0.1:27017/allpay_db

# Auth (change in production)
JWT_SECRET=change-me-in-production

# Mobile device sync (optional; required for mobile sync routes if used)
# MOBILE_SYNC_SECRET=

# S3 / LocalStack (defaults match `docker compose` on the host)
S3_ENDPOINT=http://127.0.0.1:4566
S3_PUBLIC_BASE=http://127.0.0.1:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Razorpay (optional for local dev; required when USE_RAZORPAY_UPI=true in production)
USE_RAZORPAY_UPI=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Testing only (do not use in normal dev) ---------------------------------
# USE_LIVE_MONGO=1
# MONGO_URI=mongodb://127.0.0.1:27017/allpay_test
