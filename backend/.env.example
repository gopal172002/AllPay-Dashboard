# =============================================================================
# AllPay Dashboard — backend API environment template
# =============================================================================
# Copy to `backend/.env` before `npm run dev` or `npm start`:
#   copy .env.example .env        (Windows, from backend/)
#   cp .env.example .env          (macOS / Linux)
# =============================================================================

# Server
PORT=5000
NODE_ENV=development

# MongoDB (local Docker default; or Atlas connection string from Atlas UI)
MONGO_URI=mongodb://127.0.0.1:27017/allpay_db
# If Atlas times out on Windows, set public DNS for Node (ISP DNS may not resolve mongodb.net):
# MONGO_DNS_SERVERS=8.8.8.8,1.1.1.1

# Auth (change in production)
JWT_SECRET=change-me-in-production

# Mobile device sync (optional; required for mobile sync routes if used)
# MOBILE_SYNC_SECRET=

# Receipt storage — local disk when not running LocalStack (Atlas-only / no Docker S3)
USE_LOCAL_RECEIPT_STORAGE=true
API_PUBLIC_BASE=http://localhost:5000/api

# S3 / LocalStack (set USE_LOCAL_RECEIPT_STORAGE=false when using compose localstack)
S3_ENDPOINT=http://127.0.0.1:4566
S3_PUBLIC_BASE=http://127.0.0.1:4566
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# Sightengine — AI-generated receipt detection (server-side only; never expose in frontend)
# SIGHTENGINE_API_USER=
# SIGHTENGINE_API_SECRET=
# SIGHTENGINE_AI_THRESHOLD=0.65
# ENABLE_RECEIPT_AI_CHECK=true

# Receipt fraud pipeline (metadata + Sightengine + OCR + ELA)
# ENABLE_RECEIPT_FRAUD_PIPELINE=true
# ENABLE_RECEIPT_OCR=true

# Razorpay (optional for local dev; required when USE_RAZORPAY_UPI=true in production)
USE_RAZORPAY_UPI=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- Testing only (do not use in normal dev) ---------------------------------
# USE_LIVE_MONGO=1
# MONGO_URI=mongodb://127.0.0.1:27017/allpay_test
